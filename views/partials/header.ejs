<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <!--==Title==================================-->
  <title>ThreadCycle - Buy & Sell New & Pre-Loved Fashion</title>

  <!--==Stylesheet=============================-->
  <link rel="stylesheet" type="text/css" href="Home Page CSS.css">

  <!--==Fav-icon===============================-->
  <link rel="icon" type="image/png" href="images/favicon.png">

  <!--==Using-Font-Awesome=====================-->
  <script src="https://kit.fontawesome.com/5471644867.js" crossorigin="anonymous"></script>

  <!--==API & JS Files=========================-->
  <script src="api.js" defer></script>
  <script src="Home Page JS.js" defer></script>
  <script src="js/homepageaddcart.js" defer></script>

  <!--==Fonts==================================-->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&family=Playfair+Display:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <style>
    /* ===== RESET & GLOBAL ===== */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: #faf9f7;
      scroll-behavior: smooth;
    }

    /* ===== CUSTOM NAVIGATION - FASHION FORWARD ===== */
    .navigation {
      width: 100%;
      background: #ffffff;
      backdrop-filter: blur(0px);
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03), 0 1px 2px rgba(0, 0, 0, 0.05);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 48px;
      position: sticky;
      top: 0;
      z-index: 1000;
      transition: all 0.3s ease;
      border-bottom: 2px solid #f0ede8;
    }

    /* ----- BOLD FASHION LOGO (Clothing Vibe) ----- */
    .logo {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      font-family: 'Playfair Display', serif;
      transition: transform 0.2s ease;
    }

    .logo:hover {
      transform: scale(1.02);
    }

    .logo-icon {
      background: #1e1e2a;
      width: 46px;
      height: 46px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 8px 14px rgba(0, 0, 0, 0.08);
    }

    .logo-icon i {
      font-size: 28px;
      color: #f5e7d9;
    }

    .logo-text {
      display: flex;
      flex-direction: column;
      line-height: 1.1;
    }

    .logo-text .main {
      font-size: 1.7rem;
      font-weight: 800;
      letter-spacing: -0.5px;
      background: linear-gradient(135deg, #1f1a2e, #3a2c2c);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .logo-text .sub {
      font-size: 0.6rem;
      letter-spacing: 2.2px;
      font-weight: 600;
      color: #b87333;
      text-transform: uppercase;
      margin-top: -4px;
    }

    /* menu button */
    .menu-btn {
      display: none;
    }

    .menu-icon {
      display: none;
      cursor: pointer;
      background: #f3f0eb;
      width: 44px;
      height: 44px;
      border-radius: 30px;
      align-items: center;
      justify-content: center;
    }

    .menu-icon .nav-icon {
      width: 22px;
      height: 2.5px;
      background-color: #2c2c2c;
      display: block;
      position: relative;
      transition: all 0.3s ease-in-out;
      border-radius: 4px;
    }

    .menu-icon .nav-icon::before,
    .menu-icon .nav-icon::after {
      content: '';
      width: 22px;
      height: 2.5px;
      background-color: #2c2c2c;
      position: absolute;
      left: 0;
      transition: all 0.3s ease-in-out;
      border-radius: 4px;
    }

    .menu-icon .nav-icon::before {
      top: -8px;
    }

    .menu-icon .nav-icon::after {
      top: 8px;
    }

    /* menu list - clothing store style */
    .menu {
      display: flex;
      gap: 8px;
      list-style: none;
    }

    .menu li a {
      text-decoration: none;
      color: #2d2a24;
      font-weight: 500;
      font-size: 0.95rem;
      padding: 8px 20px;
      border-radius: 40px;
      transition: all 0.25s ease;
      font-family: 'Inter', sans-serif;
    }

    .menu li a:hover,
    .menu li a.active {
      background: #d4af7a;
      color: #1e1b16;
      box-shadow: 0 4px 8px rgba(180, 130, 70, 0.2);
      transform: translateY(-2px);
    }

    /* Right Icons - refined */
    .right-nav {
      display: flex;
      gap: 18px;
      align-items: center;
    }

    .right-nav a {
      position: relative;
      font-size: 1.25rem;
      color: #2c2a27;
      background: #f5f2ed;
      width: 42px;
      height: 42px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      transition: all 0.25s ease;
      text-decoration: none;
    }

    .right-nav a:hover {
      background: #d4af7a;
      color: #1e1b16;
      transform: translateY(-3px);
    }

    .right-nav a span {
      position: absolute;
      top: -6px;
      right: -6px;
      background: #c45c2c;
      color: white;
      font-size: 11px;
      font-weight: 700;
      min-width: 20px;
      height: 20px;
      border-radius: 30px;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 2px 6px rgba(0,0,0,0.15);
      padding: 0 4px;
    }

    /* Hero section - clothing focused */
    .hero-banner {
      background: linear-gradient(115deg, #f7f3ed 0%, #fffaf3 100%);
      min-height: 80vh;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 40px 80px;
      flex-wrap: wrap;
      gap: 40px;
    }

    .hero-text {
      flex: 1;
    }

    .hero-text h1 {
      font-family: 'Playfair Display', serif;
      font-size: 3.5rem;
      font-weight: 700;
      color: #2b241c;
      line-height: 1.2;
    }

    .hero-text h1 span {
      color: #b87333;
      border-bottom: 3px solid #e2c2a0;
    }

    .hero-text p {
      font-size: 1rem;
      color: #5a4e42;
      margin: 20px 0;
      max-width: 480px;
    }

    .btn-primary {
      background: #2b241c;
      border: none;
      padding: 14px 34px;
      border-radius: 50px;
      color: #fcf7f0;
      font-weight: 600;
      font-size: 0.95rem;
      cursor: pointer;
      transition: all 0.3s;
      box-shadow: 0 5px 12px rgba(0, 0, 0, 0.1);
      display: inline-block;
      text-decoration: none;
    }

    .btn-primary:hover {
      background: #b87333;
      color: white;
      transform: translateY(-3px);
      box-shadow: 0 8px 18px rgba(184, 115, 51, 0.25);
    }

    .hero-image {
      flex: 1;
      text-align: center;
    }

    .hero-image svg {
      max-width: 100%;
      border-radius: 32px;
      background: #e6dfd4;
      padding: 12px;
    }

    /* Category cards - new & old clothes */
    .category-section {
      padding: 60px 48px;
      text-align: center;
      background: white;
    }

    .category-section h2 {
      font-family: 'Playfair Display', serif;
      font-size: 2.2rem;
      color: #2b241c;
      margin-bottom: 40px;
    }

    .clothing-grid {
      display: flex;
      justify-content: center;
      gap: 32px;
      flex-wrap: wrap;
    }

    .cloth-card {
      background: #fefaf5;
      border-radius: 28px;
      padding: 20px;
      width: 260px;
      transition: all 0.25s;
      box-shadow: 0 12px 24px -12px rgba(0, 0, 0, 0.08);
      border: 1px solid #efe3d4;
    }

    .cloth-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 24px 32px -16px rgba(0, 0, 0, 0.12);
    }

    .cloth-icon {
      font-size: 58px;
      color: #b87333;
      margin-bottom: 16px;
    }

    .cloth-card h3 {
      font-size: 1.5rem;
      font-weight: 600;
    }

    .cloth-card p {
      color: #6b5a4a;
      font-size: 0.85rem;
      margin: 8px 0;
    }

    .badge {
      background: #e4d5c2;
      padding: 4px 12px;
      border-radius: 50px;
      font-size: 0.7rem;
      font-weight: 600;
      color: #4f3b28;
      display: inline-block;
    }

    /* Featured items (old + new) */
    .featured-items {
      padding: 40px 48px 70px;
      background: #fefaf5;
    }

    .section-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.8rem;
      margin-bottom: 32px;
      text-align: center;
    }

    .item-list {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 28px;
    }

    .product {
      background: white;
      border-radius: 24px;
      width: 220px;
      padding: 18px;
      text-align: center;
      transition: 0.2s;
      border: 1px solid #efe0d0;
    }

    .product i {
      font-size: 44px;
      color: #907a62;
      margin-bottom: 12px;
    }

    .product h4 {
      font-weight: 600;
      margin: 8px 0 4px;
    }

    .price {
      font-weight: 700;
      color: #b87333;
    }

    .old-price {
      text-decoration: line-through;
      font-size: 0.8rem;
      color: #a09181;
      margin-left: 6px;
    }

    /* removed feedback and signup specific mentions, but kept other essential links */
    footer {
      background: #1e1b16;
      color: #ccc6bd;
      padding: 32px 48px;
      text-align: center;
      font-size: 0.85rem;
    }

    @media screen and (max-width: 991px) {
      .navigation {
        padding: 14px 24px;
      }
      .menu-icon {
        display: flex;
      }
      .menu {
        position: absolute;
        top: 100%;
        left: 0;
        width: 100%;
        flex-direction: column;
        background: #ffffff;
        display: none;
        border-top: 1px solid #e4d9cd;
        padding: 16px 24px;
        gap: 8px;
        box-shadow: 0 20px 30px -12px rgba(0,0,0,0.08);
      }
      .menu li a {
        display: block;
        padding: 10px 16px;
        border-radius: 50px;
      }
      .menu-btn:checked ~ .menu {
        display: flex;
      }
      .hero-banner {
        padding: 40px 24px;
        flex-direction: column;
        text-align: center;
      }
      .hero-text h1 {
        font-size: 2.5rem;
      }
      .category-section, .featured-items {
        padding: 40px 24px;
      }
    }
  </style>
</head>
<body>
  <!--==Navigation - Clothing Resale Redesign ==============================-->
  <nav class="navigation">
    <!-- NEW LOGO: ThreadCycle - Fashion Forward -->
    <a href="/" class="logo">
      <div class="logo-icon">
        <i class="fas fa-tshirt"></i>
      </div>
      <div class="logo-text">
        <span class="main">THREADCYCLE</span>
        <span class="sub">NEW & PRE-LOVED</span>
      </div>
    </a>

    <!--menu-btn (hamburger)-->
    <input type="checkbox" class="menu-btn" id="menu-btn">
    <label for="menu-btn" class="menu-icon">
      <span class="nav-icon"></span>
    </label>

    <!--menu - removed Feedback & Signup, updated for clothing store -->
    <ul class="menu">
      <li><a href="/" class="active">Home</a></li>
      <li><a href="/contact">Contact&nbsp;Us</a></li>
      <li><a href="/shop">Sell&nbsp;Clothes</a></li>      <!-- replaced feedback with sell -->
      <li><a href="/aboutus">About&nbsp;Us</a></li>
      <li><a href="/auth/login">Login</a></li>
      <li><a href="/userOrders">My&nbsp;Order</a></li>
      <li><a href="/adregister">Admin</a></li>
      <!-- No Signup or Feedback link -->
    </ul>

    <!--right-nav icons (wishlist, cart, profile)-->
    <div class="right-nav">
      <a href="/whislist" class="like" aria-label="Wishlist">
        <i class="fa-regular fa-heart"></i>
        <span>4</span>
      </a>

      <a href="/cart" class="cart" aria-label="Cart">
        <i class="fa-solid fa-cart-shopping"></i>
        <span>2</span>
      </a>

      <a href="/profile" class="user-profile" aria-label="Profile">
        <i class="fas fa-user"></i>
        <span>1</span>
      </a>
    </div>
  </nav>


  <script>
    // active link highlight based on current URL path
    (function() {
      const currentPath = window.location.pathname;
      const navLinks = document.querySelectorAll('.menu li a');
      navLinks.forEach(link => {
        const href = link.getAttribute('href');
        if (href === currentPath || (currentPath === '/' && href === '/')) {
          link.classList.add('active');
        } else if (href !== '/' && currentPath.startsWith(href) && href !== '/') {
          link.classList.add('active');
        } else if (link.classList.contains('active') && href !== currentPath) {
          link.classList.remove('active');
        }
      });
      console.log('🧥 THREADCYCLE — New & Old clothing marketplace | Feedback & SignUp removed');
    })();
  </script>
  <!-- External scripts remain for future cart/wishlist features (api.js etc) -->
</body>
</html>