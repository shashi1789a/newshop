<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <title>Wishlist</title>

  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

  <%- include('partials/header') %>

  <div class="max-w-7xl mx-auto px-5 py-10">

    <h1 class="text-4xl font-bold text-center mb-10 text-purple-700">
      My Wishlist
    </h1>

    <!-- SAFE VARIABLE -->
    <%
      const wishlistData = typeof wishlist !== 'undefined'
        ? wishlist
        : [];
    %>

    <!-- EMPTY -->
    <% if(wishlistData.length === 0){ %>

      <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

        <img
          src="https://cdn-icons-png.flaticon.com/512/102/102661.png"
          class="w-40 mx-auto mb-6"
        >

        <h2 class="text-3xl font-bold text-gray-700 mb-4">
          Wishlist Empty
        </h2>

        <p class="text-gray-500 mb-6">
          No products in wishlist
        </p>

        <a href="/products"
          class="bg-purple-600 hover:bg-purple-700 text-white px-7 py-3 rounded-xl">
          Continue Shopping
        </a>

      </div>

    <% } else { %>

      <!-- TOTAL -->
      <%
        let totalPrice = 0;

        wishlistData.forEach(item => {
          totalPrice += item.price;
        });
      %>

      <!-- PRODUCTS -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">

        <% wishlistData.forEach(product => { %>

          <div class="bg-white rounded-3xl shadow-xl overflow-hidden hover:shadow-2xl transition">

            <!-- IMAGE -->
            <img
              src="<%= product.image %>"
              alt="<%= product.name %>"
              class="w-full h-64 object-cover"
            >

            <!-- CONTENT -->
            <div class="p-5">

              <h2 class="text-2xl font-bold text-gray-800 mb-2">
                <%= product.name %>
              </h2>

              <p class="text-gray-500 mb-4">
                <%= product.description %>
              </p>

              <div class="text-3xl font-bold text-green-600 mb-5">
                ₹ <%= product.price %>
              </div>

              <!-- BUTTONS -->
              <div class="flex gap-3">

                <!-- REMOVE -->
                <a
                  href="/wishlist/remove/<%= product._id %>"
                  class="flex-1 bg-red-500 hover:bg-red-600 text-white text-center py-3 rounded-xl font-semibold"
                >
                  Remove
                </a>

                <!-- MOVE -->
                <a
                  href="/wishlist/move-to-cart/<%= product._id %>"
                  class="flex-1 bg-green-600 hover:bg-green-700 text-white text-center py-3 rounded-xl font-semibold"
                >
                  Move To Cart
                </a>

              </div>

            </div>

          </div>

        <% }) %>

      </div>

      <!-- SUMMARY -->
      <div class="mt-12 bg-white max-w-md mx-auto p-8 rounded-3xl shadow-xl">

        <h2 class="text-3xl font-bold text-center text-purple-700 mb-6">
          Wishlist Summary
        </h2>

        <div class="space-y-4 text-lg">

          <div class="flex justify-between">
            <span>Total Items</span>
            <span><%= wishlistData.length %></span>
          </div>

          <div class="flex justify-between font-bold text-2xl text-green-600">
            <span>Total Price</span>
            <span>₹ <%= totalPrice %></span>
          </div>

        </div>

      </div>

    <% } %>

  </div>
<%- include('./partials/footer') %>
</body>
</html>